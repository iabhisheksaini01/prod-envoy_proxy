static_resources:

  listeners:

{% if envoy_tls_enabled %}

    - name: listener_http_redirect
      address:
        socket_address:
          address: {{ envoy_listener_address }}
          port_value: {{ envoy_http_port }}

      filter_chains:
        - filters:
            - name: envoy.filters.network.http_connection_manager
              typed_config:
                "@type": type.googleapis.com/envoy.extensions.filters.network.http_connection_manager.v3.HttpConnectionManager

                stat_prefix: ingress_http_redirect

                route_config:
                  virtual_hosts:
                    - name: redirect_all
                      domains: ["*"]
                      routes:
                        - match:
                            prefix: "/"
                          redirect:
                            https_redirect: true

                http_filters:
                  - name: envoy.filters.http.router
                    typed_config:
                      "@type": type.googleapis.com/envoy.extensions.filters.http.router.v3.Router


    - name: listener_https
      address:
        socket_address:
          address: {{ envoy_listener_address }}
          port_value: {{ envoy_https_port }}

      filter_chains:

        - transport_socket:
            name: envoy.transport_sockets.tls
            typed_config:
              "@type": type.googleapis.com/envoy.extensions.transport_sockets.tls.v3.DownstreamTlsContext

              common_tls_context:
                tls_certificates:
                  - certificate_chain:
                      filename: {{ envoy_tls_cert_file }}
                    private_key:
                      filename: {{ envoy_tls_key_file }}

          filters:

            - name: envoy.filters.network.http_connection_manager
              typed_config:
                "@type": type.googleapis.com/envoy.extensions.filters.network.http_connection_manager.v3.HttpConnectionManager

                stat_prefix: ingress_https

                route_config:
                  name: route_config

                  virtual_hosts:

{% for vhost in envoy_virtual_hosts %}
                    - name: {{ vhost.name }}
                      domains: {{ vhost.domains | tojson }}

                      routes:

{% for route in vhost.routes %}
                        - match:
{% if route.match_type is defined and route.match_type == "exact" %}
                            path: "{{ route.prefix }}"
{% elif route.match_type is defined and route.match_type == "regex" %}
                            safe_regex:
                              google_re2: {}
                              regex: "{{ route.prefix }}"
{% else %}
                            prefix: "{{ route.prefix }}"
{% endif %}
                          route:
                            cluster: "{{ route.cluster }}"
{% if route.host_rewrite is defined %}
                            host_rewrite_literal: "{{ route.host_rewrite }}"
{% endif %}
{% if route.prefix_rewrite is defined %}
                            prefix_rewrite: "{{ route.prefix_rewrite }}"
{% endif %}
{% if route.timeout is defined %}
                            timeout: "{{ route.timeout }}"
{% endif %}
{% endfor %}

{% endfor %}

                http_filters:
                  - name: envoy.filters.http.router
                    typed_config:
                      "@type": type.googleapis.com/envoy.extensions.filters.http.router.v3.Router

{% else %}

    - name: listener_http
      address:
        socket_address:
          address: {{ envoy_listener_address }}
          port_value: {{ envoy_http_port }}

      filter_chains:

        - filters:

            - name: envoy.filters.network.http_connection_manager
              typed_config:
                "@type": type.googleapis.com/envoy.extensions.filters.network.http_connection_manager.v3.HttpConnectionManager

                stat_prefix: ingress_http

                route_config:
                  name: route_config

                  virtual_hosts:

{% for vhost in envoy_virtual_hosts %}
                    - name: {{ vhost.name }}
                      domains: {{ vhost.domains | tojson }}

                      routes:

{% for route in vhost.routes %}
                        - match:
{% if route.match_type is defined and route.match_type == "exact" %}
                            path: "{{ route.prefix }}"
{% elif route.match_type is defined and route.match_type == "regex" %}
                            safe_regex:
                              google_re2: {}
                              regex: "{{ route.prefix }}"
{% else %}
                            prefix: "{{ route.prefix }}"
{% endif %}
                          route:
                            cluster: "{{ route.cluster }}"
{% if route.host_rewrite is defined %}
                            host_rewrite_literal: "{{ route.host_rewrite }}"
{% endif %}
{% if route.prefix_rewrite is defined %}
                            prefix_rewrite: "{{ route.prefix_rewrite }}"
{% endif %}
{% if route.timeout is defined %}
                            timeout: "{{ route.timeout }}"
{% endif %}
{% endfor %}

{% endfor %}

                http_filters:
                  - name: envoy.filters.http.router
                    typed_config:
                      "@type": type.googleapis.com/envoy.extensions.filters.http.router.v3.Router

{% endif %}



  clusters:

{% for cluster in envoy_clusters %}

    - name: {{ cluster.name }}

      connect_timeout: {{ cluster.connect_timeout }}

      type: STATIC

      lb_policy: {{ cluster.lb_policy }}

{% if cluster.protocol is defined and cluster.protocol == "https" %}

      transport_socket:
        name: envoy.transport_sockets.tls
        typed_config:
          "@type": type.googleapis.com/envoy.extensions.transport_sockets.tls.v3.UpstreamTlsContext
{% if cluster.sni is defined %}
          sni: {{ cluster.sni }}
{% endif %}

{% endif %}

      dns_lookup_family: V4_ONLY

      health_checks:

        - timeout: 2s
          interval: 5s
          unhealthy_threshold: 3
          healthy_threshold: 2

          http_health_check:
            path: {{ cluster.health_check_path }}

      load_assignment:

        cluster_name: {{ cluster.name }}

        endpoints:

          - lb_endpoints:

{% for endpoint in cluster.endpoints %}

              - endpoint:
                  address:
                    socket_address:
                      address: {{ endpoint.ip }}
                      port_value: {{ endpoint.port }}

{% endfor %}

{% endfor %}



admin:

  access_log_path: /tmp/envoy_admin.log

  address:
    socket_address:
      address: {{ envoy_admin_address }}
      port_value: {{ envoy_admin_port }}
